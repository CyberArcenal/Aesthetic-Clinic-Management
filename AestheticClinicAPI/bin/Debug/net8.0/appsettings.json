{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=AestheticClinic.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Key": "your-super-secret-key-with-at-least-32-characters",
    "Issuer": "AestheticClinicAPI",
    "Audience": "AestheticClinicClient",
    "ExpiryMinutes": 60
  },
  "WeeklyReport": {
    "DayOfWeek": "Monday",
    "HourUtc": 2,
    "MinuteUtc": 0
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "Username": "deetvofficial2@gmail.com",
    "Password": "rhrukhuxwpmsbnna",
    "From": "noreply@yourclinic.com"
  },
  "Frontend": {
    "BaseUrl": "https://yourclinic.com"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
